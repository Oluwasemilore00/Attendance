# Copy this file to .env and fill in your values.
FLASK_ENV=development
SECRET_KEY=your-random-64-char-hex-secret
JWT_SECRET_KEY=your-random-64-char-hex-jwt-secret

# PostgreSQL in production (leave unset to use local SQLite):
# DATABASE_URL=postgresql://user:pass@host:5432/quick_attendance

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30
CORS_ORIGINS=http://localhost:5173
DEFAULT_ATTENDANCE_THRESHOLD=75
RATELIMIT_STORAGE_URI=memory://

